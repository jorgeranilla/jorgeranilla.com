rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/familyDirectory/$(request.auth.uid))
        && get(/databases/$(database)/documents/familyDirectory/$(request.auth.uid)).data.role == 'admin'
        && get(/databases/$(database)/documents/familyDirectory/$(request.auth.uid)).data.status == 'approved';
    }

    function isApprovedMember() {
      return signedIn()
        && exists(/databases/$(database)/documents/familyDirectory/$(request.auth.uid))
        && get(/databases/$(database)/documents/familyDirectory/$(request.auth.uid)).data.status == 'approved';
    }

    function isImportedRecord(userId) {
      return userId.matches('import_.*')
        || userId.matches('manual_.*')
        || (resource.data.uid is string && resource.data.uid.matches('import_.*'))
        || (resource.data.uid is string && resource.data.uid.matches('manual_.*'));
    }

    function isOwnProfile(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /familyDirectory/{userId} {
      allow read: if isAdmin()
                  || isApprovedMember()
                  || isOwnProfile(userId)
                  || (signedIn() && isImportedRecord(userId));

      allow create: if isAdmin()
                    || (
                      isOwnProfile(userId)
                      && request.resource.data.uid == userId
                      && request.resource.data.role == 'member'
                      && request.resource.data.status == 'pending'
                    );

      allow update: if isAdmin()
                    || (
                      isOwnProfile(userId)
                      && resource.data.status == 'pending'
                      && request.resource.data.uid == resource.data.uid
                      && request.resource.data.role == resource.data.role
                      && request.resource.data.status == resource.data.status
                    );

      allow delete: if isAdmin();
    }

    match /familyMemberRequests/{requestId} {
      function isOwnRequest() {
        return signedIn() && resource.data.memberId == request.auth.uid;
      }

      function isAllowedRequestType() {
        return request.resource.data.type in ['profile_update', 'photo_add', 'photo_remove'];
      }

      function isCreatingOwnPendingRequest() {
        return isApprovedMember()
          && request.resource.data.memberId == request.auth.uid
          && request.resource.data.status == 'pending'
          && isAllowedRequestType()
          && request.resource.data.payload is map
          && request.resource.data.keys().hasOnly([
            'type',
            'status',
            'memberId',
            'memberName',
            'memberEmail',
            'payload',
            'createdAt',
            'updatedAt'
          ]);
      }

      allow read: if isAdmin() || isOwnRequest();
      allow create: if isCreatingOwnPendingRequest();
      allow update, delete: if isAdmin();
    }

    match /familyPhotoTags/{photoId} {
      allow read: if resource.data.status == 'approved'
                  || isApprovedMember()
                  || isAdmin();

      allow create, update, delete: if isAdmin();
    }

    match /familyPhotoTagSuggestions/{suggestionId} {
      allow read, update, delete: if isAdmin();
      allow create: if false;
    }

    match /familyPhotoTagSuggestionRateLimits/{rateLimitId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}