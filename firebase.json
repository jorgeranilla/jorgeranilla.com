{
  "database": {
    "rules": "locator/firebase-database.rules.json"
  },
  "firestore": {
    "rules": "family-directory/firestore.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**", "functions/**", "umsteadgrove/**"],
    "rewrites": [],
    "headers": [
      {
        "source": "/umsteadgrove/admin.html",
        "headers": [{ "key": "X-Robots-Tag", "value": "noindex" }]
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs22"
    }
  ]
}
