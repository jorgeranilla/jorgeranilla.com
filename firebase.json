{
  "database": {
    "rules": "locator/firebase-database.rules.json"
  },
  "firestore": {
    "rules": "family-directory/firestore.rules"
  },
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      "deploy-*.bat",
      "firepit-log.txt",
      "**/*.ps1",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "umsteadgrove/**"
    ],
    "rewrites": [],
    "headers": []
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs22"
    }
  ]
}
