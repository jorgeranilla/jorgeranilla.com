# Umstead Grove FSBO — Firebase Secrets
# Set these using: firebase functions:secrets:set SECRET_NAME

# SMTP credentials for sending emails (e.g., Gmail App Password, SendGrid, or Mailgun)
UG_SMTP_HOST=smtp.gmail.com
UG_SMTP_PORT=587
UG_SMTP_USER=youremail@gmail.com
UG_SMTP_PASS=your-app-password-here

# Seller's email address (receives lead notifications)
UG_SELLER_EMAIL=seller@yourdomain.com

# Simple password to protect the admin panel API endpoints
# Use a strong random string (e.g., from: openssl rand -base64 32)
UG_ADMIN_PASSWORD=replace-with-strong-random-password
